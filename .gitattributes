# Shell scripts MUST stay LF-only — they run on the Linux deploy box (bash chokes
# on CRLF: `\r` becomes part of args/paths). Force LF in the working tree too, so a
# Windows checkout that gets rsync'd to the box never carries CRLF.
*.sh text eol=lf

# Binary demo assets — NEVER apply text/CRLF normalization (it corrupts the byte
# stream, and poppler / an image decoder would then reject the file).
*.png binary
*.pdf binary
*.jpg binary
*.jpeg binary

# Frozen evaluation text is hashed byte-for-byte. Force LF in every checkout so
# Windows core.autocrlf cannot invalidate the preregistered evidence protocol.
eval/dataset.sha256 text eol=lf
eval/vision/manifest.json text eol=lf
eval/vision/fixtures.sha256 text eol=lf
runtime-packages.lock text eol=lf
runtime-apk-inventory.lock text eol=lf
runtime-apk-archives.sha256 text eol=lf
.syft.yaml text eol=lf
.grype.yaml text eol=lf
eval/promotion-poppler.lock.json text eol=lf
eval/results/evidence-ledger.json text eol=lf
eval/results/*-attempt-*.json text eol=lf

# Final publication evidence is mutually hash-bound. Keep its canonical UTF-8/LF
# bytes in every checkout so Windows core.autocrlf cannot invalidate the recorder,
# SRT, narration provenance, QA, or final real-motion manifest.
demo/gallery/CAPTURE_REVIEW.json text eol=lf
demo/final-media/*.srt text eol=lf
demo/final-media/*.json text eol=lf
demo/media-tools/narration-script.json text eol=lf
demo/media-tools/narration-voice.lock.json text eol=lf

# Impact evidence hashes the LF-canonical UTF-8 text form and the replay inputs
# are pinned LF in every checkout. This makes the source/evidence binding stable
# across Windows and Linux without weakening lone-CR rejection in the analyzer.
.gitattributes text eol=lf
src/** text eol=lf
eval/lib.ts text eol=lf
eval/dataset.ts text eol=lf
eval/artifact-safety.ts text eol=lf
eval/promotion-environment.ts text eol=lf
eval/protocol-provenance.ts text eol=lf
impact/*.mjs text eol=lf
impact/*.json text eol=lf
impact/*.md text eol=lf
package.json text eol=lf
package-lock.json text eol=lf
tsconfig.json text eol=lf
