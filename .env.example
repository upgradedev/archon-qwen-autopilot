# ── Qwen / Alibaba Cloud Model Studio (DashScope) ────────────────────────────
# Create a key in the Model Studio console. When absent, the app auto-falls back
# to the deterministic offline Fake chat client + Fake embedder, so the WHOLE
# workflow (intake → decide → approve → execute) runs in dev + CI with NO key.
DASHSCOPE_API_KEY=

# OpenAI-compatible base URL. Default is the hackathon international endpoint.
# China (Beijing) alternative: https://dashscope.aliyuncs.com/compatible-mode/v1
# Workspace-scoped form also works: https://<WorkspaceId>.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Qwen chat model that drives the multi-step ReAct decision loop.
QWEN_MODEL=qwen-plus

# Qwen VISION model for real document uploads (POST /intake/document): a PDF/PNG/JPG
# invoice is read into structured fields by this model. Absent a DASHSCOPE key the
# app uses the deterministic FakeExtractionClient, so the upload path runs with no
# key in dev + CI. Default is the flagship DashScope vision model.
VISION_MODEL=qwen-vl-max

# Upload guardrails for /intake/document (optional).
# MAX_DOCUMENT_BYTES caps the upload size; MAX_PDF_PAGES caps pages rasterized.
MAX_DOCUMENT_BYTES=10485760
MAX_PDF_PAGES=3
# poppler binary used to rasterize PDFs (installed in the Docker image).
POPPLER_PDFTOPPM=pdftoppm

# Max steps in the bounded ReAct loop before the safe flag_for_review fallback.
# Optional — defaults to 8 (leaves headroom past the 5 autonomous read/analyze tools).
AUTOPILOT_MAX_STEPS=8

# Qwen text-embedding model + dimension. text-embedding-v4 defaults to 1024,
# which matches the vector(1024) memory column. Keep the two in lockstep.
QWEN_EMBED_MODEL=text-embedding-v4
EMBED_DIM=1024

# ── Memory store: pgvector-compatible PostgreSQL ─────────────────────────────
# Local dev / CI: a stock pgvector/pgvector docker image.
# Production: Alibaba Cloud AnalyticDB for PostgreSQL or ApsaraDB RDS for
# PostgreSQL (pgvector extension) — same pg-wire protocol, same SQL.
# When unset, the server can still run with in-memory stores (offline demo/tests).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
PGPOOL_MAX=5

# Daily upload caps for the open demo (POST /intake · /intake/stream ·
# /intake/document · /extract/document share one budget, per UTC day). Protects the
# Qwen API budget on an unauthenticated endpoint. Two tiers, both optional:
#   UPLOAD_DAILY_LIMIT        — per-client (per-IP) cap.       Code default: 100.
#   UPLOAD_GLOBAL_DAILY_LIMIT — global backstop across clients. Code default: 2000.
# The example values below are a small, safe demo setting; raise them for a judging
# window. The global backstop is the hard total-spend bound (the per-client key is
# best-effort behind a proxy — see src/ap/rate-limit.ts).
UPLOAD_DAILY_LIMIT=100
UPLOAD_GLOBAL_DAILY_LIMIT=2000

# ── Vendor-reply email sink (real SMTP) ──────────────────────────────────────
# The one REAL terminal-action sink: when a human approves a draft_vendor_reply,
# SmtpEmailSink (src/ap/smtp-sink.ts) delivers an actual email over SMTP. All of
# these are OPTIONAL — when SMTP_HOST is unset the app uses the in-memory Fake email
# sink and NOTHING is sent, so dev + CI stay offline. Setting SMTP_HOST switches the
# vendor-reply action to real delivery, still strictly behind the human approval gate.
#   SMTP_HOST   — SMTP server hostname. UNSET → simulate (send nothing).
#   SMTP_PORT   — default 587 (STARTTLS). Use 465 with SMTP_SECURE=true for implicit TLS.
#   SMTP_SECURE — true → implicit TLS (port 465); default false → STARTTLS.
#   SMTP_USER / SMTP_PASS — auth credentials (auth is used only when BOTH are set).
#   SMTP_FROM   — envelope From address (defaults to SMTP_USER).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Journal-entry ledger sink (real durable JSONL) ───────────────────────────
# The SECOND real terminal-action sink: when a human approves a draft_journal_entry,
# JsonlLedgerSink (src/ap/ledger-sink.ts) appends the approved double-entry accrual —
# one JSON object per line — to a real, durable, append-only JSONL ledger file. OPTIONAL:
# when LEDGER_JSONL_PATH is unset the app uses the in-memory Fake ledger sink and NOTHING
# is written, so dev + CI stay offline. Setting it switches the journal-entry action to a
# real durable append, still strictly behind the human approval gate. A Postgres-backed
# ledger would drop in behind the same LedgerTransport seam.
#   LEDGER_JSONL_PATH — path to the append-only JSONL ledger. UNSET → simulate (write nothing).
LEDGER_JSONL_PATH=

# ── HTTP server ──────────────────────────────────────────────────────────────
# Function Compute custom-container default CAPort is 9000.
PORT=9000
