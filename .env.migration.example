# Copy to `.env.migration` on the deployment host (gitignored, mode 0600).
# This bootstrap/admin credential is used only by the one-shot migration container
# and must never be placed in `.env` or passed to the serving container.
MIGRATION_DATABASE_URL=postgresql://<bootstrap-admin>:<bootstrap-password>@db:5432/postgres

# Generate at least 32 random bytes. The same encoded value must appear in the
# dedicated runtime DATABASE_URL stored in `.env`.
AUTOPILOT_APP_DB_PASSWORD=<random-32-plus-byte-secret>

# Required cross-app isolation target on the same PostgreSQL cluster. Its fixed
# `memoryagent_app` runtime role must already exist; bootstrap fails before changing
# the Memory database ACL otherwise. Set this to
# the real neighbouring Memory database (`memoryagent` on the hardened topology,
# or `postgres` only for the legacy layout). Bootstrap fails if it does not exist.
MEMORY_DATABASE_NAME=memoryagent
